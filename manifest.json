{
  "name": "FELT GeoJSON Uploader",
  "short_name": "FELT",
  "description": "Draw or upload GeoJSON and publish to your Felt map",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#e63946",
  "icons": [
    { "src": "apple-touch-icon.png", "sizes": "180x180", "type": "image/png" },
    { "src": "icon-192.png",         "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "icon-512.png",         "sizes": "512x512", "type": "image/png", "purpose": "maskable" },
    { "src": "icon.svg",             "sizes": "any",      "type": "image/svg+xml" }
  ],
  "share_target": {
    "action": "./?share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text":  "text",
      "url":   "url",
      "files": [
        {
          "name": "geojson",
          "accept": [
            "application/geo+json",
            "application/json",
            ".geojson",
            ".json"
          ]
        }
      ]
    }
  }
}
